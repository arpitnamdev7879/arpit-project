# TalentGPT Environment Variables
# Copy this to .env and fill in your keys

# Required: Google Gemini API Key
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Token for higher rate limits (60 → 5000 req/hr)
# Get at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here

# Database (SQLite by default — no setup needed!)
DATABASE_URL=sqlite:///./talentgpt.db
